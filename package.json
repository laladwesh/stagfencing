{
  "name": "stagfencing",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm run server\" \"npm run client\"",
    "install:client": "cd client && npm install",
    "build": "npm run install:client && cd client && npm run build",
    "start": "cross-env NODE_ENV=production node server.js",
    "seed": "node server/seed.js",
    "seed:services": "node server/seed-services.js",
    "migrate:style-ids": "node server/migrate-style-ids.js",
    "bootstrap:admin": "node server/bootstrap-admin.js",
    "seed:gallery": "node server/seed-gallery.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.8.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14"
  }
}
