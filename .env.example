# Local dev: mongodb://127.0.0.1:27017/stagfencing
# Production (Docker container talking to a Mongo already running on the host):
# mongodb://host.docker.internal:27017/stagfencing
MONGODB_URI=mongodb://127.0.0.1:27017/stagfencing
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (Sign in with Google) — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# SMTP (for real OTP email delivery). If unset, OTP codes are logged to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Stag Fencing <no-reply@stagfencing.com.au>"

# AWS S3 (review/product photo uploads)
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe (checkout card payments)
STRIPE_SECRET_KEY=

# Docker/production only — ignored by local `npm run dev`
PORT=3000
NODE_ENV=production

# Frontend build-time vars — for local dev these go in client/.env instead.
# For Docker/production, keep them here too: docker-compose reads this file and
# passes them as build args so they get baked into the React bundle correctly.
# REACT_APP_GOOGLE_CLIENT_ID must match GOOGLE_CLIENT_ID above.
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_STRIPE_PUBLISHABLE_KEY=
