MONGODB_URI=mongodb://127.0.0.1:27017/stagfencing
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (Sign in with Google) — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# SMTP (for real OTP email delivery). If unset, OTP codes are logged to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Stag Fencing <no-reply@stagfencing.com.au>"

# Frontend build-time var (set in client/.env) — must match GOOGLE_CLIENT_ID above
REACT_APP_GOOGLE_CLIENT_ID=
